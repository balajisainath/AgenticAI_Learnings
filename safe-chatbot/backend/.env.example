# ── LLM Provider ────────────────────────────────────────────────────────────
# Choose one: openai | anthropic | google_genai
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Google
# GOOGLE_API_KEY=...
# GOOGLE_MODEL=gemini-2.0-flash

# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173
LLM_TEMPERATURE=0.4

# ── NeMo Guardrails ──────────────────────────────────────────────────────────
# Disable NVIDIA telemetry (optional)
# NEMO_GUARDRAILS_NO_USAGE_STATS=1
