# LLM Provider: openai | anthropic | google
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google
GOOGLE_API_KEY=...
GOOGLE_MODEL=gemini-2.0-flash

# App
APP_ENV=development
DATABASE_URL=sqlite+aiosqlite:///./prompt_playground.db
