APP_NAME=Career Advisor AI API
APP_ENV=development

# openai | anthropic | google_genai (alias: google)
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.2
RAG_TOP_K=6

DEEP_AGENT_ENABLED=false
DEEP_AGENT_MODEL=openai:gpt-4o-mini
TAVILY_API_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Comma-separated list, e.g. http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173
